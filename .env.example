# Flask environment
FLASK_ENV=development

# Required secret used by Flask sessions and verification tokens.
# Use a long random value. Do not reuse this exact example.
SECRET_KEY=replace-this-with-a-long-random-secret-key

# Local development database.
# Leave this as SQLite if you do not want to run PostgreSQL locally.
DATABASE_URL=sqlite:///tasks.db

# Example PostgreSQL format:
# DATABASE_URL=postgresql://username:password@localhost:5432/database_name
